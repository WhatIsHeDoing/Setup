{
    "[markdown]": {
        "editor.codeActionsOnSave": {
            "source.fixAll.markdownlint": "always"
        },
        "editor.defaultFormatter": "yzhang.markdown-all-in-one"
    },
    "editor.codeActionsOnSave": {
        "source.fixAll": "always"
    },
    "editor.formatOnSave": true,
    "editor.rulers": [
        130
    ],
    "files.associations": {
        ".ansible-lint": "yaml",
        "*.yml.example": "yaml",
        "config/gitignore_global": "ignore",
        "scripts/*": "shellscript"
