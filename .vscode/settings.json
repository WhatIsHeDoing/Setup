{
    "cSpell.diagnosticLevel": "Information",
    "cSpell.language": "en-GB,en",
    "cSpell.words": [
        "Amberol",
        "asciicast",
        "asciinema",
        "bootstrapper",
        "Cascadia",
        "Grype",
        "handoff",
        "Justfile",
        "linted",
        "Powerline",
        "runtimes",
        "shellcheck",
        "winget"
    ],
    "editor.codeActionsOnSave": {
        "source.fixAll": "always"
    },
    "editor.formatOnSave": true,
    "files.associations": {
        ".ansible-lint": "yaml",
        "scripts/*": "shellscript"
    }
}
